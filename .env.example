# =============================================================================
# Ads of Stupid — environment variables
# Copy this file to ".env.local" and fill in the values you want to use.
# Every lead is ALWAYS saved to the backend (data/leads.json -> admin /admin/leads).
# Everything below is OPTIONAL: it only adds email/WhatsApp notifications.
# If a block is left blank, that notification is simply skipped.
# =============================================================================

# --- Owner email alert (when a new lead comes in) -----------------------------
# Uses Resend (https://resend.com). Create an API key + verify your domain.
RESEND_API_KEY=
LEAD_NOTIFY_TO=hello@adsofstupid.com
# "From" must be on a domain you've verified in Resend, e.g.:
LEAD_NOTIFY_FROM=Ads of Stupid <leads@adsofstupid.com>

# --- WhatsApp via Interakt (https://www.interakt.ai) --------------------------
# API key from Interakt -> Settings -> Developer Settings (use the secret key).
INTERAKT_API_KEY=
# Approved WhatsApp template names (create them in Interakt).
# Owner alert template — receives {name, phone, source} as body variables.
INTERAKT_OWNER_TEMPLATE=
# Your WhatsApp number to receive owner alerts (digits only or +91…).
OWNER_WHATSAPP=918530639877
# Lead confirmation template — receives {name} as the body variable.
INTERAKT_LEAD_TEMPLATE=

# --- Optional: also mirror leads to a Google Sheet ----------------------------
# A Google Apps Script web-app URL that appends a row per lead.
GOOGLE_APPS_SCRIPT_URL=
