# =============================================================================
# Ads of Stupid — environment variables
# Copy this file to ".env.local" and fill in the values you want to use.
# Every lead is ALWAYS saved to the backend (data/leads.json -> admin /admin/leads).
# Everything below is OPTIONAL: it only adds email/WhatsApp notifications.
# If a block is left blank, that notification is simply skipped.
# =============================================================================

# --- Database (REQUIRED for leads + blogs) ------------------------------------
# Postgres connection string from Neon (neon.tech) or Supabase. Use the POOLED
# connection string. Without it, blog content falls back to samples and writes
# (new leads, blog edits) are disabled.
DATABASE_URL=

# --- Analytics: Google Tag Manager (carries Meta Pixel + GA4) ------------------
# Reuse your EXISTING GTM container ID (same as your current site). Leave blank
# to disable. Public var — exposed to the browser by design.
NEXT_PUBLIC_GTM_ID=
# Meta Pixel — only if it's NOT already a tag inside your GTM container
# (installing it both here and in GTM double-counts events).
NEXT_PUBLIC_FB_PIXEL_ID=

# --- Admin login (REQUIRED to access /admin) ----------------------------------
# Without these set, no one can log into the admin panel.
ADMIN_USERNAME=admin@adsofstupid.com
ADMIN_PASSWORD=change-this-to-a-strong-password
# Long random string used to sign the admin session cookie.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# --- Owner email alert (when a new lead comes in) -----------------------------
# Uses Resend (https://resend.com). Create an API key + verify your domain.
RESEND_API_KEY=
LEAD_NOTIFY_TO=hello@adsofstupid.com
# "From" must be on a domain you've verified in Resend, e.g.:
LEAD_NOTIFY_FROM=Ads of Stupid <leads@adsofstupid.com>

# --- FREE WhatsApp owner alert via CallMeBot (https://www.callmebot.com) -------
# Pings the owner's WhatsApp on every lead. Get the key by messaging
# +34 644 51 95 23 the text: "I allow callmebot to send me messages".
CALLMEBOT_PHONE=918530639877
CALLMEBOT_APIKEY=

# --- FREE WhatsApp confirmation TO THE LEAD (Meta WhatsApp Cloud API) ----------
# The only no-cost way to auto-message a lead. Needs a Meta WhatsApp app + an
# APPROVED template whose body has one {{1}} variable (the lead's name).
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_CLOUD_PHONE_ID=
WHATSAPP_CLOUD_LEAD_TEMPLATE=
WHATSAPP_CLOUD_LANG=en

# --- WhatsApp via Interakt (https://www.interakt.ai) --------------------------
# API key from Interakt -> Settings -> Developer Settings (use the secret key).
INTERAKT_API_KEY=
# Approved WhatsApp template names (create them in Interakt).
# Owner alert template — receives {name, phone, source} as body variables.
INTERAKT_OWNER_TEMPLATE=
# Your WhatsApp number to receive owner alerts (digits only or +91…).
OWNER_WHATSAPP=918530639877
# Lead confirmation template — receives {name} as the body variable.
INTERAKT_LEAD_TEMPLATE=

# --- Optional: also mirror leads to a Google Sheet ----------------------------
# A Google Apps Script web-app URL that appends a row per lead.
GOOGLE_APPS_SCRIPT_URL=
